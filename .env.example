# ─── Runtime & security ───────────────────────────────────────────────────────
APP_ENV=dev                       # dev | staging | production
# Comma-separated browser origins allowed by CORS.
CORS_ORIGINS=http://localhost:3100
# REQUIRED in staging/production — the API refuses to start with the default key.
SIGNING_SECRET=docos-dev-signing-secret

# ─── Privacy mode: offline | enterprise | cloud ───────────────────────────────
PRIVACY_MODE=offline

# ─── Blob storage: local | s3 ─────────────────────────────────────────────────
BLOB_BACKEND=local
LOCAL_BLOB_DIR=./data/blobs

# S3 / MinIO (used when BLOB_BACKEND=s3)
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=docos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Database & queue ─────────────────────────────────────────────────────────
# POSTGRES_* are consumed by docker-compose.prod.yml to provision the database.
POSTGRES_USER=docos
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=docos
DATABASE_URL=postgresql+psycopg://docos:docos@postgres:5432/docos
REDIS_URL=redis://redis:6379/0

# ─── LLM provider: noop | openai | anthropic ──────────────────────────────────
# noop = fully offline (AI features show a "Connect AI" state). To turn AI on (natural-
# language edits, autopilot, Q&A, translation) you only need to set an API key — just
# fill in ANTHROPIC_API_KEY (recommended) or OPENAI_API_KEY below and the app auto-selects
# that provider. Set LLM_PROVIDER explicitly only to force a specific provider.
# LLM_MODEL applies to Anthropic only (OpenAI deployments ignore it): optionally pin a
# model, e.g. claude-sonnet-4-6 for cheaper high-volume Q&A; blank = the Anthropic client's
# default, currently claude-opus-4-8.
LLM_PROVIDER=noop
LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Embedded editor providers ────────────────────────────────────────────────
# local/basic keeps the current safe editor. Configure these to enable native
# Office/PDF editor embeds without pretending the fallback is Acrobat/Office parity.
OFFICE_EDITOR_PROVIDER=local       # local | onlyoffice
ONLYOFFICE_DOCUMENT_SERVER_URL=
PDF_EDITOR_PROVIDER=basic          # basic | external
PDF_EDITOR_URL=

# ─── Ingestion limits ─────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50
ALLOWED_MIME_TYPES=text/plain,text/markdown,text/x-markdown,text/csv,application/csv,text/html,application/xhtml+xml,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/rtf,image/png,image/jpeg,image/tiff

# ─── Frontend ─────────────────────────────────────────────────────────────────
# The web app proxies /api/* to the backend server-side, so the browser never
# calls the API directly (no CORS needed). Set this to the URL the WEB SERVER can
# reach the backend at — a private/internal hostname in production.
# Local pnpm dev (backend on the host): http://localhost:8000
# Docker Compose web service overrides this to http://api:8000 automatically.
# Railway single-service default: http://127.0.0.1:8000
# Railway split service: http://${{api.RAILWAY_PRIVATE_DOMAIN}}:${{api.PORT}}
API_PROXY_TARGET=http://localhost:8000
# Optional: set to "split" only when Railway Web and API are separate services; this enables
# a production warning if API_PROXY_TARGET is accidentally left on localhost.
DOCOS_RAILWAY_TOPOLOGY=single
