# ─── Runtime & security ───────────────────────────────────────────────────────
APP_ENV=dev                       # dev | staging | production
# Comma-separated browser origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000
# REQUIRED in staging/production — the API refuses to start with the default key.
SIGNING_SECRET=docos-dev-signing-secret

# ─── Privacy mode: offline | enterprise | cloud ───────────────────────────────
PRIVACY_MODE=offline

# ─── Blob storage: local | s3 ─────────────────────────────────────────────────
BLOB_BACKEND=local
LOCAL_BLOB_DIR=./data/blobs

# S3 / MinIO (used when BLOB_BACKEND=s3)
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=docos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Database & queue ─────────────────────────────────────────────────────────
# POSTGRES_* are consumed by docker-compose.prod.yml to provision the database.
POSTGRES_USER=docos
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=docos
DATABASE_URL=postgresql+psycopg://docos:docos@postgres:5432/docos
REDIS_URL=redis://redis:6379/0

# ─── LLM provider: noop | openai | anthropic ──────────────────────────────────
LLM_PROVIDER=noop
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Ingestion limits ─────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50
ALLOWED_MIME_TYPES=text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/rtf,image/png,image/jpeg,image/tiff

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
