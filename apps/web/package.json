{
  "name": "@docos/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy-pdf-worker": "node ./scripts/copy-pdf-worker.mjs",
    "predev": "node ./scripts/copy-pdf-worker.mjs",
    "dev": "next dev -p 3100",
    "prebuild": "node ./scripts/copy-pdf-worker.mjs",
    "build": "next build && node ./scripts/assemble-standalone.mjs",
    "prebuild:standalone": "node ./scripts/copy-pdf-worker.mjs",
    "build:standalone": "DOCOS_NEXT_STANDALONE=1 next build && node ./scripts/assemble-standalone.mjs",
    "start": "node .next/standalone/apps/web/server.js",
    "lint": "next lint",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@docos/shared-types": "workspace:*",
    "@tanstack/react-query": "^5.51.0",
    "@univerjs/presets": "^0.25.1",
    "lucide-react": "^1.21.0",
    "next": "14.2.35",
    "pdfjs-dist": "^4.10.38",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3"
  }
}
