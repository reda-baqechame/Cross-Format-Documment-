{
  "name": "cross-format-document-os",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-Format Document Operating System — open, edit, convert and run trust operations on any document.",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:web": "pnpm --filter @docos/web dev",
    "build:web": "pnpm --filter @docos/web build",
    "codegen": "openapi-typescript http://localhost:8000/openapi.json -o packages/shared-types/src/generated.ts",
    "lint:web": "pnpm --filter @docos/web lint",
    "smoke:production": "node scripts/production-smoke.mjs",
    "smoke:production:client-packet": "node scripts/production-client-packet-smoke.mjs",
    "smoke:production:client-packet:ui": "pnpm --filter @docos/web exec node ../../scripts/production-client-packet-ui-smoke.mjs",
    "smoke:production:editor": "pnpm --filter @docos/web exec node ../../scripts/production-editor-smoke.mjs",
    "smoke:production:auth": "node scripts/production-auth-portal-smoke.mjs",
    "smoke:production:full": "node scripts/production-full-test.mjs",
    "smoke:production:matrix": "node scripts/production-tool-matrix.mjs",
    "eval:document-ops": "python evals/document_ops/run_local.py"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0"
  }
}
